<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" name="DT-MonitoringPlan" id="DT-MonitoringPlan">
  <decision id="d1" name="MonitoringPlan">
    <decisionTable hitPolicy="FIRST">
      <input id="i1"><inputExpression typeRef="boolean"><text>monitoring.onBasalBolus</text></inputExpression></input>
      <input id="i2"><inputExpression typeRef="boolean"><text>monitoring.smbgStructured</text></inputExpression></input>

      <output id="o1" name="monitoringRecommendation" typeRef="string" />
      <output id="o2" name="preferredMonitoringMode" typeRef="string" />
      <output id="o3" name="sidRef" typeRef="string" />

      <rule id="r1">
        <inputEntry><text>= true</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"maintain structured monitoring"</text></outputEntry>
        <outputEntry><text>"no-preference-between-cgm-and-capillary"</text></outputEntry>
        <outputEntry><text>"6.2"</text></outputEntry>
      </rule>

      <rule id="r2">
        <inputEntry><text>= false</text></inputEntry>
        <inputEntry><text>= false</text></inputEntry>
        <outputEntry><text>"start structured capillary monitoring"</text></outputEntry>
        <outputEntry><text>"structured-capillary"</text></outputEntry>
        <outputEntry><text>"6.1"</text></outputEntry>
      </rule>

      <rule id="r3">
        <inputEntry><text>= false</text></inputEntry>
        <inputEntry><text>= true</text></inputEntry>
        <outputEntry><text>"continue structured capillary monitoring"</text></outputEntry>
        <outputEntry><text>"structured-capillary"</text></outputEntry>
        <outputEntry><text>"6.1"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>
</definitions>
