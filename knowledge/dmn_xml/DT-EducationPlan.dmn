<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" name="DT-EducationPlan" id="DT-EducationPlan">
  <decision id="d1" name="EducationPlan">
    <decisionTable hitPolicy="FIRST">
      <input id="i1"><inputExpression typeRef="boolean"><text>education.structuredEducationDone</text></inputExpression></input>
      <input id="i2"><inputExpression typeRef="boolean"><text>education.groupEducationFeasible</text></inputExpression></input>

      <output id="o1" name="recommendStructuredEducation" typeRef="boolean" />
      <output id="o2" name="educationMode" typeRef="string" />
      <output id="o3" name="sidRef" typeRef="string" />

      <rule id="r1">
        <inputEntry><text>= false</text></inputEntry>
        <inputEntry><text>= true</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"group"</text></outputEntry>
        <outputEntry><text>"4.2"</text></outputEntry>
      </rule>

      <rule id="r2">
        <inputEntry><text>= false</text></inputEntry>
        <inputEntry><text>= false</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"individual"</text></outputEntry>
        <outputEntry><text>"4.1"</text></outputEntry>
      </rule>

      <rule id="r3">
        <inputEntry><text>= true</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"4.1"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>
</definitions>
